<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Board dimensions calculated for Realme 8 (2400 x 1080 in landscape) -->
    <!-- Board Width: 84.375% of 2400px = 2025px -->
    <dimen name="boardWidth" tools:ignore="PxUsage">2025px</dimen>
    <!-- Board Height: 83.055% of 1080px = 897px -->
    <dimen name="boardHeight" tools:ignore="PxUsage">897px</dimen>
    <dimen name="boardMarginBottom" tools:ignore="PxUsage">0.0099px</dimen>

    <!-- Canvas (drawing boundaries) -->
    <!-- Canvas Width: 90% of boardWidth = 1822.5px -->
    <dimen name="canvasWidth" tools:ignore="PxUsage">1822.5px</dimen>
    <dimen name="canvasHeight" tools:ignore="PxUsage">731px</dimen>
    <dimen name="canvasMarginTop" tools:ignore="PxUsage">82px</dimen>

    <!-- Buttons -->
    <dimen name="buttonWidth" tools:ignore="PxUsage">260px</dimen>
    <dimen name="buttonHeight" tools:ignore="PxUsage">75px</dimen>
    <dimen name="buttonNormalMarginStart" tools:ignore="PxUsage">185px</dimen>
    <dimen name="buttonNineBallMarginEnd" tools:ignore="PxUsage">30px</dimen>
    <dimen name="buttonCloseMarginEnd" tools:ignore="PxUsage">170px</dimen>
</resources>
